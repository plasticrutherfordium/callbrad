---
import Layout from '../layouts/Layout.astro';
import { bookingUrl, testimonials } from '../data/site';
import { dpoPackages, trainingOffer, workspacePackages } from '../data/offers';
---

<Layout title="Call Brad | Operational GDPR For Lean Teams" description="GDPR workspaces, training and DPO support for lean teams.">
  <section class="pt-20 pb-12 lg:pt-24 lg:pb-14 bg-gradient-to-br from-white via-gray-50 to-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#2b2e83]/5 rounded-full mb-4">
        <span class="w-2 h-2 bg-[#ed60ed] rounded-full"></span>
        <span class="text-sm font-medium text-[#2b2e83]">GDPR workspaces, training and DPO support</span>
      </div>
      <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#2b2e83] leading-tight mb-4">
        Operational GDPR for lean teams
      </h1>
      <p class="text-lg sm:text-xl lg:text-2xl font-medium text-[#2b2e83] max-w-4xl mx-auto mb-6">
        Your GDPR system, built where your team already works. No heavy privacy software. No scattered spreadsheets. No compliance theatre.
      </p>
      <div class="max-w-5xl mx-auto mb-6">
        <img
          src="/imgs_callbrad/homepage-call-brad-pic-v2.svg"
          alt="Call Brad GDPR workspace illustration"
          class="w-full h-auto"
          loading="eager"
        />
      </div>
      <div class="mb-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 mb-4">
          Built in the tools your team already uses
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-5">
          <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
            <img
              src="https://logo.svgcdn.com/devicon/notion-original.svg"
              alt="Notion"
              class="h-8 w-auto"
              loading="lazy"
            />
          </div>
          <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
            <img
              src="https://logo.svgcdn.com/logos/atlassian.svg"
              alt="Atlassian"
              class="h-8 w-auto"
              loading="lazy"
            />
          </div>
          <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
            <img
              src="https://logo.svgcdn.com/devicon/google-original.svg"
              alt="Google"
              class="h-8 w-auto"
              loading="lazy"
            />
          </div>
        </div>
      </div>
      <div class="flex justify-center">
        <a href={bookingUrl} class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-colors no-underline">
          Book an intro call
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-18 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/gdpr-workspace" class="group bg-white rounded-3xl p-8 border-2 border-[#2b2e83]/20 hover:border-[#2b2e83] transition-all hover:shadow-xl hover:shadow-[#2b2e83]/10 no-underline">
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[#2b2e83]/70 mb-3">Notion GDPR Workspace</div>
          <div class="font-montserrat text-3xl font-bold text-[#2b2e83] mb-3">{workspacePackages[0].shortPrice}</div>
          <p class="text-gray-600 text-sm mb-4">Connected GDPR records, clearer ownership, rollout support, and practical setup in Notion.</p>
          <p class="text-sm font-medium text-gray-700 mb-5">See Essential, Operational, and Growth side by side</p>
          <span class="inline-flex items-center text-[#2b2e83] font-medium">See workspace packages</span>
        </a>

        <a href="/dpo" class="group bg-white rounded-3xl p-8 border border-gray-200 hover:border-[#2b2e83]/50 transition-all hover:shadow-xl hover:shadow-gray-200/60 no-underline">
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-3">DPO Services</div>
          <div class="font-montserrat text-3xl font-bold text-[#2b2e83] mb-3">{dpoPackages[0].shortPrice}</div>
          <p class="text-gray-600 text-sm mb-4">Monthly DPO support with fixed pricing and visible scope.</p>
          <p class="text-sm font-medium text-gray-700 mb-5">{dpoPackages[0].bestFor}</p>
          <span class="inline-flex items-center text-[#2b2e83] font-medium">See DPO packages</span>
        </a>

        <a href="/training" class="group bg-white rounded-3xl p-8 border-2 border-[#ed60ed]/30 hover:border-[#ed60ed] transition-all hover:shadow-xl hover:shadow-[#ed60ed]/10 no-underline">
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[#ed60ed]/70 mb-3">Employee GDPR Training</div>
          <div class="font-montserrat text-3xl font-bold text-[#ed60ed] mb-3">{trainingOffer.price}</div>
          <p class="text-gray-600 text-sm mb-4">Training available now in Notion and Google Workspace.</p>
          <p class="text-sm font-medium text-gray-700 mb-5">{trainingOffer.bestFor}</p>
          <span class="inline-flex items-center text-[#ed60ed] font-medium">See training</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr] lg:items-stretch">
        <div class="rounded-3xl bg-[#2b2e83] p-8 text-white">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/70 mb-4">
            Client results
          </p>
          <h2 class="font-montserrat text-3xl font-bold leading-tight">
            Built for teams who need GDPR support that works inside real operations.
          </h2>
        </div>

        <div class="grid gap-6">
          {testimonials.map((testimonial) => (
            <figure class="rounded-3xl border border-gray-200 bg-gray-50 p-8 shadow-sm">
              <blockquote class="m-0 max-w-none font-montserrat text-xl font-semibold leading-relaxed text-[#2b2e83]">
                &ldquo;{testimonial.quote}&rdquo;
              </blockquote>
              <div class="mt-8 flex flex-col gap-5 border-t border-gray-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#2b2e83]/70">
                    {testimonial.company} ({testimonial.country})
                  </p>
                  <figcaption class="mt-2 text-sm text-gray-600">
                    <span class="font-semibold text-[#222222]">{testimonial.name}</span>, {testimonial.role}
                  </figcaption>
                </div>
                <img
                  src={testimonial.logo}
                  alt={`${testimonial.company} logo`}
                  class="max-h-9 max-w-28 object-contain"
                  loading="lazy"
                />
              </div>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-18 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-3">
          Why Call Brad
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          A clearer middle ground between static templates and heavy software.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-3xl p-8">
          <h3 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-3">More useful than static templates</h3>
          <p class="text-sm text-gray-600">Built around working records, ownership, and follow-up rather than isolated documents.</p>
        </div>
        <div class="bg-gray-50 rounded-3xl p-8">
          <h3 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-3">Lighter than enterprise privacy software</h3>
          <p class="text-sm text-gray-600">Start with the structure teams need now before buying a heavier software layer.</p>
        </div>
        <div class="bg-gray-50 rounded-3xl p-8">
          <h3 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-3">More operational than ceremonial DPO support</h3>
          <p class="text-sm text-gray-600">Visible packages, add-ons, and discounts instead of vague support promises.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-gray-200 bg-gray-50 px-6 py-6 text-center shadow-sm lg:flex lg:items-center lg:justify-between lg:gap-8 lg:text-left">
        <p class="font-semibold text-[#2b2e83]">IAPP-certified privacy professionals</p>
        <div class="my-6 flex flex-wrap items-center justify-center gap-3 lg:my-0">
          <img src="/imgs_callbrad/cipp2.png" alt="CIPP/E credential" class="h-12 w-auto" loading="lazy" />
          <img src="/imgs_callbrad/cipp3.png" alt="CIPP/US credential" class="h-12 w-auto" loading="lazy" />
          <img src="/imgs_callbrad/cipt.png" alt="CIPT credential" class="h-12 w-auto" loading="lazy" />
          <img src="/imgs_callbrad/cipm.png" alt="CIPM credential" class="h-12 w-auto" loading="lazy" />
          <img src="/imgs_callbrad/fip.png" alt="FIP credential" class="h-12 w-auto" loading="lazy" />
        </div>
        <p class="max-w-sm text-gray-600">Built for lean teams that need GDPR to be maintained, not just documented</p>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-18 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
        See the offer in detail
      </h2>
      <p class="text-gray-600 mb-8">Explore the workspace, DPO services, or go straight to a call.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/gdpr-workspace" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-colors">
          Explore the workspace
        </a>
        <a href={bookingUrl} class="px-8 py-4 bg-white text-[#2b2e83] font-semibold rounded-xl border-2 border-[#2b2e83] hover:bg-[#2b2e83]/5 transition-colors">
          Book an intro call
        </a>
      </div>
    </div>
  </section>
</Layout>
