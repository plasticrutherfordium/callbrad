---
import Layout from '../layouts/Layout.astro';
import { bookingUrl } from '../data/site';
import { trainingOffer } from '../data/offers';
---

<Layout title="GDPR Training | Call Brad" description="GDPR training available now in Notion and Google Workspace, priced per employee.">
  <section class="pt-20 pb-12 lg:pt-24 lg:pb-14 bg-gradient-to-br from-[#ed60ed]/5 via-white to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#ed60ed]/10 rounded-full mb-4">
          <span class="w-2 h-2 bg-[#2b2e83] rounded-full"></span>
          <span class="text-sm font-semibold text-[#ed60ed]">GDPR Training</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#ed60ed] leading-tight mb-4">
          GDPR training that lives where your team already works
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-6 max-w-3xl mx-auto">
          You pay once, add it to the tools your team already uses, and reuse it as needed. No other expensive platform or subscription.
        </p>
        <div class="mx-auto mb-7 aspect-video max-w-2xl overflow-hidden rounded-2xl bg-gray-900 shadow-sm">
          <iframe
            class="h-full w-full"
            src="https://www.youtube-nocookie.com/embed/Obfti9ym5G0"
            title="Call Brad GDPR training preview video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <div class="mb-7">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 mb-4">
            You choose where to deliver it
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-5">
            <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
              <img
                src="https://logo.svgcdn.com/devicon/google-original.svg"
                alt="Google"
                class="h-8 w-auto"
                loading="lazy"
              />
            </div>
            <div class="flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
              <img
                src="https://logo.svgcdn.com/devicon/notion-original.svg"
                alt="Notion"
                class="h-8 w-auto"
                loading="lazy"
              />
            </div>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#pricing" class="px-8 py-4 bg-[#ed60ed] text-white font-semibold rounded-xl hover:bg-[#d94dd9] transition-all hover:shadow-lg hover:shadow-[#ed60ed]/25">
            See package
          </a>
          <a href={bookingUrl} class="px-8 py-4 bg-white text-[#ed60ed] font-semibold rounded-xl border-2 border-[#ed60ed] hover:bg-[#ed60ed]/5 transition-colors">
            Book an intro call
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="pricing" class="py-14 lg:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#ed60ed] mb-3">
          Training pricing and delivery
        </h2>
        <p class="text-gray-600 max-w-3xl mx-auto">
          A one-off employee training product with clear onboarding, support, extras, and rollout effort.
        </p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full border-separate border-spacing-0 overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm">
          <tbody class="align-top">
            <tr>
              <td class="w-[34%] border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                One-off License &amp; Onboarding Fee
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                <p>{trainingOffer.fullPrice} (existing + new employee)</p>
                <p>{trainingOffer.minimum}</p>
                <p>{trainingOffer.bulkDiscount}</p>
              </td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                Product functionality
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                <ul class="space-y-2">
                  <li>Access to 25+ videos covering essential GDPR topics</li>
                  <li>30 expert-designed questions</li>
                  <li>Test results / completion log for all test-takers</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                Included in onboarding
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                <p>30 mins quick start &amp; customisation with expert</p>
                <ul class="mt-2 space-y-2">
                  <li>Setup in your environment in Notion or Google Workspace</li>
                  <li>Short owner walkthrough</li>
                  <li>Team introduction email template</li>
                  <li>Basic launch guidance</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                Ongoing Technical Support
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                Email, next business day
              </td>
            </tr>
            <tr class="bg-gray-100">
              <td class="border-b border-gray-200 px-6 py-4 font-semibold uppercase tracking-[0.14em] text-gray-600">
                Extras
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-4"></td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                Customisation for separate teams
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                €100 per team + VAT
              </td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                <div>Immediate Implementation</div>
                <div class="mt-1 font-normal text-gray-500">(start within 1 business day)</div>
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                Additional €300 + VAT
              </td>
            </tr>
            <tr>
              <td class="border-b border-gray-200 bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                <div>Custom videos &amp; quiz sections</div>
                <div class="mt-1 font-normal text-gray-500">(up to 2 mins, delivered within 2 weeks, no client IP rights)</div>
              </td>
              <td class="border-b border-l border-gray-200 px-6 py-5 text-gray-700">
                Additional €250 / topic + VAT
              </td>
            </tr>
            <tr>
              <td class="bg-gray-50 px-6 py-5 font-semibold text-gray-900">
                Operational time commitments by Call Brad expert
              </td>
              <td class="border-l border-gray-200 px-6 py-5 text-gray-700">
                <p class="font-semibold text-[#2b2e83]">Up to 1 hour</p>
                <ul class="mt-2 space-y-2">
                  <li>30 mins setup in Notion/Google</li>
                  <li>30 mins owner walkthrough / email support</li>
                </ul>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section id="features" class="py-14 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#ed60ed] mb-4">
          Why teams choose this training
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Designed to be easy to deliver, easy to maintain, and practical inside real team workflows.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#ed60ed] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Practical business relevance</h3>
            <p class="text-gray-600">Clear employee GDPR training that directly applies to daily work and responsibilities.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#ed60ed] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Easy to deliver & maintain</h3>
            <p class="text-gray-600">Available now in Notion and Google Workspace, so rollout can stay closer to tools your team already uses.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#ed60ed] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Product, not just an add-on</h3>
            <p class="text-gray-600">Presented as a clear product with visible pricing, not a vague side offer.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#ed60ed] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Structured completion</h3>
            <p class="text-gray-600">Designed for practical learning with a clear cohort-based commercial model.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#ed60ed] mb-4">
          Example coverage areas
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          The training can cover the core GDPR topics teams typically need for day-to-day awareness and handling.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Data protection basics</h3>
          <p class="text-gray-600 text-sm">Understanding personal data, data subjects, and the core privacy principles teams need to work with daily.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Rights and requests</h3>
          <p class="text-gray-600 text-sm">Handling rights-related requests and routing them clearly inside the business.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Data handling</h3>
          <p class="text-gray-600 text-sm">Practical handling of personal data inside real working processes.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Breach response</h3>
          <p class="text-gray-600 text-sm">What teams should do when something goes wrong and how to escalate internally.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Security practices</h3>
          <p class="text-gray-600 text-sm">Password hygiene, device handling, and safer everyday behaviour around personal data.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200">
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Third-party data</h3>
          <p class="text-gray-600 text-sm">Working with vendors and external partners without losing track of privacy responsibilities.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-20 bg-gradient-to-b from-[#ed60ed]/10 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#ed60ed] mb-6">
        Train your team effectively
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Use the existing booking link if you want to discuss team size, rollout timing, and whether Notion or Google Workspace is the better fit.
      </p>
      <a href={bookingUrl} class="px-8 py-4 bg-[#ed60ed] text-white font-semibold rounded-xl hover:bg-[#d94dd9] transition-all hover:shadow-lg hover:shadow-[#ed60ed]/25">
        Book an intro call
      </a>
    </div>
  </section>
</Layout>
