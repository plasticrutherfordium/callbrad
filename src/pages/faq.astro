---
import Layout from '../layouts/Layout.astro';
import { bookingUrl, contactEmail } from '../data/site';
import { dpoAddOns, dpoPackages, trainingOffer, workspaceBuyerDpoDiscounts } from '../data/offers';

const faqSections = [
  {
    title: 'Availability',
    eyebrow: 'Current offer',
    items: [
      {
        question: 'What is available now?',
        answer:
          'The Notion GDPR Teamspace, employee GDPR training for Notion and Google Workspace teams, and DPO support packages are available now.',
      },
      {
        question: 'What is coming soon?',
        answer:
          'Full Confluence and Google Workspace versions of the GDPR Teamspace are planned next. At present, the complete teamspace offer is live in Notion only.',
      },
      {
        question: 'Can we use our existing tools?',
        answer:
          'Yes. The offer is designed around practical GDPR implementation inside tools lean teams already use, rather than adding unnecessary enterprise software overhead.',
      },
    ],
  },
  {
    title: 'Pricing',
    eyebrow: 'Packages and discounts',
    items: [
      {
        question: 'Is pricing already fixed for every offer?',
        answer:
          `Yes. Teamspace package details are listed on the GDPR Teamspace page. DPO packages are ${dpoPackages.map((pkg) => `${pkg.name} ${pkg.price}${pkg.billing} + VAT`).join(', ')}. Training is ${trainingOffer.price}, with ${trainingOffer.minimum.toLowerCase()} and a ${trainingOffer.bulkDiscount.toLowerCase()}.`,
      },
      {
        question: 'Is there a DPO discount for teamspace buyers?',
        answer:
          `${workspaceBuyerDpoDiscounts.map((item) => `${item.discount} on ${item.package}`).join(', ')} for the first 3 months. Discounts do not apply to add-ons.`,
      },
      {
        question: 'What DPO add-ons are available?',
        answer:
          dpoAddOns.map((addon) => `${addon.name}: ${addon.price}`).join(', '),
      },
    ],
  },
  {
    title: 'Fit and scope',
    eyebrow: 'Who it is for',
    items: [
      {
        question: 'Who is the offer for?',
        answer:
          'Call Brad is built for startups, SaaS companies, fintechs, SMEs, and other lean teams that need structured GDPR support without a heavy consultancy or software implementation.',
      },
      {
        question: 'Are Confluence and Google Workspace teamspace versions live now?',
        answer:
          'No. The full GDPR Teamspace is currently available in Notion. Full Confluence and Google Workspace teamspace versions are still coming soon.',
      },
    ],
  },
];
---

<Layout title="FAQ | Call Brad" description="Frequently asked questions about the Call Brad GDPR teamspace, DPO services, and training offer.">
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 lg:pt-28 lg:pb-24">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-[#2b2e83]/10 bg-[#2b2e83]/5 px-4 py-2 mb-6">
          <span class="w-2 h-2 bg-[#ed60ed] rounded-full"></span>
          <span class="text-sm font-semibold text-[#2b2e83]">FAQ</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-[#2b2e83] mb-5">
          Clear answers before you book a call
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
          Practical details on availability, pricing, discounts, and delivery scope for the GDPR Teamspace, training, and DPO support.
        </p>
      </div>

      <div class="mt-12 max-w-4xl mx-auto">
        <div class="divide-y divide-gray-200 border-y border-gray-200">
          {faqSections.map((section) => (
            <section class="py-8">
              <div class="mb-5 text-center">
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#ed60ed]">{section.eyebrow}</p>
                <h2 class="mt-2 font-montserrat text-2xl font-bold text-[#2b2e83]">{section.title}</h2>
              </div>

              <div class="space-y-3">
                {section.items.map((item) => (
                  <details class="group rounded-2xl border border-gray-200 bg-white transition-colors open:border-[#2b2e83]/30 open:bg-[#2b2e83]/[0.03]">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-5 px-5 py-5 [&::-webkit-details-marker]:hidden">
                      <span class="font-montserrat text-lg font-bold leading-snug text-gray-950">{item.question}</span>
                      <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-100 text-[#2b2e83] transition-transform group-open:rotate-180">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
                        </svg>
                      </span>
                    </summary>
                    <div class="px-5 pb-5 -mt-1">
                      <p class="max-w-3xl text-base leading-relaxed text-gray-600">{item.answer}</p>
                    </div>
                  </details>
                ))}
              </div>
            </section>
          ))}
        </div>

        <div class="mt-12 rounded-2xl border border-gray-200 bg-gray-50 p-6 text-center sm:p-8">
          <p class="font-montserrat text-2xl font-bold text-[#2b2e83]">Need a specific answer?</p>
          <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-gray-600">
            Send the question by email or book a short intro call. The current offer is intentionally lightweight, so most scope questions can be resolved quickly.
          </p>
          <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
            <a href={bookingUrl} class="inline-flex items-center justify-center rounded-xl bg-[#2b2e83] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#232465]">
              Book an intro call
            </a>
            <a href={`mailto:${contactEmail}`} class="inline-flex items-center justify-center rounded-xl border border-[#2b2e83]/20 bg-white px-6 py-3 text-sm font-semibold text-[#2b2e83] transition-colors hover:bg-[#2b2e83]/5">
              Email Call Brad
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
