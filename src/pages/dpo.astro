                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Appointed DPO for 1 entity, 1 jurisdiction
            </li>
          </ul>
          <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="block text-center px-6 py-3 bg-[#2b2e83] text-white font-semibold rounded-lg hover:bg-[#232465] transition-colors">
            Get Started
          </a>
        </div>

        <!-- Growth -->
        <div class="bg-white rounded-2xl p-8 border border-gray-200 hover:border-[#2b2e83]/30 transition-all">
