---
import Layout from '../layouts/Layout.astro';
import { bookingUrl } from '../data/site';
import { dpoAddOns, dpoPackages, iappCredentials, workspaceBuyerDpoDiscounts } from '../data/offers';
---

<Layout title="DPO Services | Call Brad" description="Monthly DPO support packages with fixed pricing, add-ons, and workspace-buyer discounts.">
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-32 bg-gradient-to-br from-gray-100 via-white to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-200 rounded-full mb-6">
          <span class="w-2 h-2 bg-[#2b2e83] rounded-full"></span>
          <span class="text-sm font-semibold text-gray-700">DPO Services</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#2b2e83] leading-tight mb-6">
          DPO support for teams that need clear monthly structure, not ad hoc privacy advice
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-6 max-w-3xl mx-auto">
          Call Brad provides package-based DPO support for lean teams that need a designated and operationally useful privacy function with visible pricing, defined scope, and practical ongoing support.
        </p>
        <p class="text-base sm:text-lg text-gray-500 mb-10 max-w-3xl mx-auto">
          IAPP credentials including {iappCredentials.join(', ')} support the work, while the offer stays commercially clear and operationally focused.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#packages" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
            See packages
          </a>
          <a href={bookingUrl} class="px-8 py-4 bg-white text-[#2b2e83] font-semibold rounded-xl border-2 border-[#2b2e83] hover:bg-[#2b2e83]/5 transition-colors">
            Book an intro call
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="packages" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
          Choose the right DPO package
        </h2>
        <p class="text-gray-600 max-w-3xl mx-auto">
          Three monthly packages designed for lean teams that need practical GDPR oversight, visible scope, and clearer support expectations.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {dpoPackages.map((pkg, index) => (
          <div class:list={['bg-white rounded-2xl p-8 transition-all relative', index === 1 ? 'border-2 border-[#2b2e83] shadow-lg shadow-[#2b2e83]/10' : 'border border-gray-200 hover:border-[#2b2e83]/30']}>
            {index === 1 && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-[#2b2e83] text-white text-sm font-semibold rounded-full">
                Most popular
              </div>
            )}
            <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-2">{pkg.name} DPO</h3>
            <p class="text-gray-600 text-sm mb-6">{pkg.summary}</p>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-4xl font-bold text-[#2b2e83]">{pkg.price}</span>
              <span class="text-gray-500">{pkg.billing}</span>
            </div>
            <ul class="space-y-3 mb-8">
              {pkg.points.map((point) => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <svg class="w-5 h-5 text-[#2b2e83] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  {point}
                </li>
              ))}
            </ul>
            <a href={bookingUrl} class:list={['block text-center px-6 py-3 font-semibold rounded-lg transition-colors', index === 1 ? 'bg-[#2b2e83] text-white hover:bg-[#232465]' : 'border-2 border-[#2b2e83] text-[#2b2e83] hover:bg-[#2b2e83] hover:text-white']}>
              Book an intro call
            </a>
          </div>
        ))}
      </div>

      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-8">
        <div class="bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-6 text-center">Add-ons</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            {dpoAddOns.map((addon, index) => (
              <div class="flex flex-col items-center text-center">
                <div class:list={['w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mb-3', index === 3 ? 'bg-[#ed60ed]/10' : 'bg-[#2b2e83]/10']}>
                  <svg class:list={['w-5 h-5', index === 3 ? 'text-[#ed60ed]' : 'text-[#2b2e83]']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">{addon.name}</h4>
                  <p class="text-sm text-gray-600">{addon.summary}</p>
                  <p class:list={['text-lg font-bold mt-1', index === 3 ? 'text-[#ed60ed]' : 'text-[#2b2e83]']}>{addon.price}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-[#2b2e83]/20">
          <h3 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-4">Workspace buyer DPO discount</h3>
          <ul class="space-y-3 text-gray-700 mb-4">
            {workspaceBuyerDpoDiscounts.map((item) => (
              <li><strong>{item.discount}</strong> on {item.package}</li>
            ))}
          </ul>
          <p class="text-sm text-gray-500">
            First 12 months only. Excludes add-ons and urgent support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-6">
            Why teams choose this DPO structure
          </h2>
          <p class="text-lg text-gray-600 mb-6">
            The aim is not to turn DPO work into vague consultancy time. The aim is to give teams a clearer monthly structure, practical support, and a visible way to combine operational privacy work with the rest of the Call Brad offer.
          </p>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-700">A designated support structure with visible scope and fixed package pricing</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-700">Practical monthly support that sits alongside the workspace and training offers</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-gray-700">IAPP-backed credibility through {iappCredentials.join(', ')}</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <h3 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-4">How it pairs with the workspace</h3>
          <p class="text-gray-600 mb-4">
            Teams that buy a workspace package can reduce first-year DPO package pricing, while keeping add-ons and urgent support outside the discount.
          </p>
          <a href={bookingUrl} class="inline-flex items-center px-6 py-3 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-colors">
            Book an intro call
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gradient-to-b from-gray-100 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-6">
        Ready to put a more structured DPO setup in place?
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Use the existing booking link if you want to compare packages, add-ons, and workspace-buyer discounts.
      </p>
      <a href={bookingUrl} class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
        Book an intro call
      </a>
    </div>
  </section>
</Layout>
