            Get Started
          </a>
        </div>
      </div>

      <!-- Add-ons -->
      <div class="bg-white rounded-2xl p-8 border border-gray-200">
        <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-6">Add-ons</h3>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-[#2b2e83]/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#2b2e83]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
