---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DPO Services | Call Brad">
  <!-- Hero Section -->
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-32 bg-gradient-to-br from-gray-100 via-white to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-200 rounded-full mb-6">
          <span class="w-2 h-2 bg-[#2b2e83] rounded-full"></span>
          <span class="text-sm font-semibold text-gray-700">DPO Services</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#2b2e83] leading-tight mb-6">
          DPO support for businesses that need something more practical than ad hoc advice
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
          Ongoing package-based support for businesses that need a designated and operationally useful DPO setup. Clear, practical, and compliance-focused.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
            Get started
          </a>
