---
import Layout from '../layouts/Layout.astro';
import { bookingUrl } from '../data/site';
import { dpoAddOns, dpoPackages, trainingOffer, workspaceBuyerDpoDiscounts, workspacePackages } from '../data/offers';
---

<Layout title="Pricing | Call Brad" description="Pricing for the Call Brad GDPR Workspace, DPO services, and GDPR Training.">
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-32 bg-gradient-to-br from-white via-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#2b2e83]/5 rounded-full mb-6">
          <span class="w-2 h-2 bg-[#ed60ed] rounded-full"></span>
          <span class="text-sm font-medium text-[#2b2e83]">Pricing</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl font-bold text-[#2b2e83] mb-6">
          Clear pricing across the workspace, DPO services, and training
        </h1>
        <p class="text-lg text-gray-600">
          The commercial structure is designed to be inspectable before a call, with approved pricing across the core offers and clear discount rules where they apply.
        </p>
      </div>

      <div class="space-y-12">
        <div>
          <div class="text-center mb-10">
            <h2 class="font-montserrat text-3xl font-bold text-[#2b2e83] mb-3">GDPR Workspace</h2>
            <p class="text-gray-600">Available now in Notion. Full Confluence and Google Workspace workspace versions are coming soon.</p>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            {workspacePackages.map((pkg, index) => (
              <div class:list={['bg-white rounded-2xl p-8 transition-all', index === 1 ? 'border-2 border-[#2b2e83] shadow-lg shadow-[#2b2e83]/10' : 'border border-gray-200']}>
                <h3 class="font-montserrat text-xl font-bold text-gray-900 mb-2">{pkg.name}</h3>
                <div class="text-4xl font-bold text-[#2b2e83] mb-5">{pkg.price}<span class="text-lg text-gray-500 font-medium"> {pkg.billing}</span></div>
                <p class="text-sm text-gray-600">{pkg.summary}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-8 items-start">
          <div class="grid md:grid-cols-3 gap-6">
            {dpoPackages.map((pkg, index) => (
              <div class:list={['bg-white rounded-2xl p-8', index === 1 ? 'border-2 border-[#2b2e83] shadow-lg shadow-[#2b2e83]/10' : 'border border-gray-200']}>
                <h2 class="font-montserrat text-xl font-bold text-gray-900 mb-2">{pkg.name} DPO</h2>
                <div class="text-4xl font-bold text-[#2b2e83] mb-5">{pkg.price}<span class="text-lg text-gray-500 font-medium">{pkg.billing}</span></div>
                <ul class="space-y-3 text-sm text-gray-700">
                  {pkg.points.map((point) => <li>{point}</li>)}
                </ul>
              </div>
            ))}
          </div>

          <div class="space-y-6">
            <div class="bg-white rounded-2xl p-8 border border-gray-200">
              <h2 class="font-montserrat text-xl font-bold text-[#2b2e83] mb-4">Add-ons</h2>
              <ul class="space-y-4 text-sm text-gray-700">
                {dpoAddOns.map((addon) => <li><strong>{addon.name}:</strong> {addon.price}</li>)}
              </ul>
            </div>

            <div class="bg-white rounded-2xl p-8 border border-[#2b2e83]/20">
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[#2b2e83]/70 mb-3">Workspace buyer DPO discount</div>
              <h2 class="font-montserrat text-2xl font-bold text-[#2b2e83] mb-3">First-year DPO discount</h2>
              <ul class="space-y-3 text-gray-700 mb-4">
                {workspaceBuyerDpoDiscounts.map((item) => <li><strong>{item.discount}</strong> on {item.package}</li>)}
              </ul>
              <p class="text-sm text-gray-500">First 12 months only. Excludes add-ons and urgent support.</p>
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-[1fr_0.9fr] gap-8 items-start">
          <div class="bg-white rounded-2xl p-8 border border-[#ed60ed]/20">
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[#ed60ed]/70 mb-3">GDPR Training</div>
            <h2 class="font-montserrat text-3xl font-bold text-[#ed60ed] mb-3">{trainingOffer.price}</h2>
            <ul class="space-y-3 text-gray-700">
              <li>{trainingOffer.minimum}</li>
              <li>{trainingOffer.bulkDiscount}</li>
              <li>Available now in Notion and Google Workspace</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-2xl p-8">
            <h2 class="font-montserrat text-2xl font-bold text-[#2b2e83] mb-4">Commercial summary</h2>
            <p class="text-gray-600">
              The workspace and training offers are positioned as clear products, while DPO services remain a serious secondary offer with fixed monthly pricing and separate add-ons.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href={bookingUrl} class="inline-flex items-center px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-colors">
          Book an intro call
        </a>
      </div>
    </div>
  </section>
</Layout>
