---
import { bookingUrl } from '../../data/site';
import { workspaceDetailedPackages } from '../../data/offers';
---

<section class="pt-20 pb-12 lg:pt-24 lg:pb-14 bg-gradient-to-br from-[#2b2e83]/5 via-white to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#2b2e83]/10 rounded-full mb-4">
        <span class="w-2 h-2 bg-[#ed60ed] rounded-full"></span>
        <span class="text-sm font-semibold text-[#2b2e83]">GDPR Teamspace</span>
      </div>
      <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#2b2e83] leading-tight mb-4">
        A practical GDPR tool that your team will actually use
      </h1>
      <p class="text-lg sm:text-xl text-gray-600 mb-6 max-w-3xl mx-auto">
        Call Brad helps teams get lean by moving GDPR out of disconnected documents and into a practical and interconnected operating setup.
      </p>
      <div class="mb-7 flex flex-col items-center gap-3">
        <div class="inline-flex items-center justify-center gap-3 rounded-2xl border border-gray-200 bg-white px-5 py-4 text-center shadow-sm">
            <img
              src="https://logo.svgcdn.com/devicon/notion-original.svg"
              alt="Notion"
              class="h-10 w-auto"
              loading="lazy"
            />
            <span class="text-sm font-semibold text-[#2b2e83]">Available now</span>
        </div>
        <p class="text-sm text-gray-500">
          Full Confluence and Google Workspace versions coming soon.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#packages" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
          See packages
        </a>
        <a href={bookingUrl} class="px-8 py-4 bg-white text-[#2b2e83] font-semibold rounded-xl border-2 border-[#2b2e83] hover:bg-[#2b2e83]/5 transition-colors">
          Book an intro call
        </a>
      </div>
    </div>
  </div>
</section>

<section id="packages" class="py-14 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
        Teamspace packages
      </h2>
      <p class="text-gray-600 max-w-3xl mx-auto">
        The current teamspace offer is available now in Notion. Full Confluence and Google Workspace teamspace versions remain coming soon only.
      </p>
    </div>

    <div class="space-y-6 lg:hidden">
      {workspaceDetailedPackages.map((pkg, index) => (
        <article class:list={['rounded-2xl border bg-white p-6', index === 1 ? 'border-2 border-[#2b2e83] shadow-lg shadow-[#2b2e83]/10' : 'border-gray-200']}>
          <div class="mb-5">
            <h3 class="font-montserrat text-2xl font-bold text-[#2b2e83]">{pkg.name}</h3>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="text-4xl font-bold text-[#2b2e83]">{pkg.price}</span>
              <span class="text-gray-500">{pkg.billing}</span>
              <span class="text-sm font-semibold text-gray-500">+ VAT</span>
            </div>
          </div>

          <div class="space-y-5">
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Best for</div>
              <p class="text-sm text-gray-700">{pkg.bestFor}</p>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Typical time to be up and running</div>
              <p class="text-sm text-gray-700">{pkg.typicalTime}</p>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Included in onboarding</div>
              <p class="text-sm text-gray-700 mb-2">{pkg.onboardingLead}</p>
              <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                {pkg.onboardingItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Product functionality</div>
              {pkg.functionalityLead && <p class="text-sm text-gray-700 mb-2">{pkg.functionalityLead}</p>}
              <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                {pkg.functionalityItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Technical support</div>
              <p class="text-sm text-gray-700">{pkg.technicalSupport}</p>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-2">Operational time commitments by Call Brad expert</div>
              <p class="text-lg font-bold text-[#2b2e83] mb-2">{pkg.operationalCommitmentHours}</p>
              <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                {pkg.operationalCommitmentItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <div class="rounded-xl bg-gray-50 p-4">
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 mb-3">Extras</div>
              <div class="space-y-3 text-sm text-gray-700">
                <div>
                  <p class="font-medium text-gray-900">Immediate implementation</p>
                  <p>{pkg.immediateImplementation}</p>
                </div>
                <div>
                  <p class="font-medium text-gray-900">Additional expert hours</p>
                  <p>{pkg.additionalExpertHours}</p>
                </div>
                <div>
                  <p class="font-medium text-gray-900">Technical updates</p>
                  <p>Technical updates are only for customers of the Operational DPO and Growth DPO Packages.</p>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="hidden lg:block overflow-x-auto">
      <table class="min-w-[1120px] w-full border-separate border-spacing-0 overflow-hidden rounded-3xl border border-gray-200">
        <thead>
          <tr class="bg-gray-50">
            <th class="w-64 border-b border-gray-200 px-6 py-5 text-left text-sm font-semibold uppercase tracking-[0.14em] text-gray-500">
              Package detail
            </th>
            {workspaceDetailedPackages.map((pkg, index) => (
              <th class:list={['border-b border-l border-gray-200 px-6 py-5 text-left align-top', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>
                <div class="font-montserrat text-3xl font-bold text-[#2b2e83] mb-2">{pkg.name}</div>
                <div class="flex items-baseline gap-2">
                  <span class="text-4xl font-bold text-[#2b2e83]">{pkg.price}</span>
                  <span class="text-gray-500">{pkg.billing}</span>
                  <span class="text-sm font-semibold text-gray-500">+ VAT</span>
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="align-top">
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Best for</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5 text-gray-700', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>{pkg.bestFor}</td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Typical time to be up and running</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5 text-gray-700', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>{pkg.typicalTime}</td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Included in onboarding</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>
                <p class="mb-3 text-gray-900">{pkg.onboardingLead}</p>
                <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                  {pkg.onboardingItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Product functionality</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>
                {pkg.functionalityLead && <p class="mb-3 text-[#2b2e83] font-medium">{pkg.functionalityLead}</p>}
                <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                  {pkg.functionalityItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Technical support</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5 text-gray-700', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>{pkg.technicalSupport}</td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Operational time commitments by Call Brad expert</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>
                <p class="mb-3 text-xl font-bold text-[#2b2e83]">{pkg.operationalCommitmentHours}</p>
                <ul class="list-disc space-y-2 pl-5 text-sm text-gray-700">
                  {pkg.operationalCommitmentItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </td>
            ))}
          </tr>
          <tr class="bg-gray-50">
            <td class="border-b border-gray-200 px-6 py-4 font-semibold uppercase tracking-[0.14em] text-gray-600">Extras</td>
            <td class="border-b border-l border-gray-200 px-6 py-4"></td>
            <td class="border-b border-l border-gray-200 px-6 py-4 bg-[#2b2e83]/5"></td>
            <td class="border-b border-l border-gray-200 px-6 py-4"></td>
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Immediate implementation</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5 text-gray-700', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>{pkg.immediateImplementation}</td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Additional expert hours</td>
            {workspaceDetailedPackages.map((pkg, index) => (
              <td class:list={['border-b border-l border-gray-200 px-6 py-5 text-gray-700', index === 1 ? 'bg-[#2b2e83]/5' : 'bg-white']}>{pkg.additionalExpertHours}</td>
            ))}
          </tr>
          <tr>
            <td class="border-b border-gray-200 px-6 py-5 font-semibold text-gray-900">Technical updates</td>
            <td colspan="3" class="border-b border-l border-gray-200 bg-white px-6 py-5 text-gray-700">
              Technical updates are only for customers of the Operational DPO and Growth DPO Packages.
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section id="features" class="py-14 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
        What the teamspace is designed to do
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        A collaborative GDPR setup for records, review logic, follow-up work, and ongoing operational ownership.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
        <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Available now in Notion</h3>
          <p class="text-gray-600">Launch with the current Notion-based version rather than waiting for a heavier software rollout.</p>
        </div>
      </div>

      <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
        <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Built for operational GDPR</h3>
          <p class="text-gray-600">Support connected records, clear owners, review dates, and practical workflows rather than static documentation alone.</p>
        </div>
      </div>

      <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
        <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Lighter than bloated tools</h3>
          <p class="text-gray-600">A more practical starting point for startups and SMEs that do not need enterprise overhead as their first move.</p>
        </div>
      </div>

      <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
        <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Room for future refinement</h3>
          <p class="text-gray-600">The structure can support future screenshots, workflow examples, testimonials, and pricing details without redesigning the page.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-14 lg:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-6">
          How the current teamspace offer is positioned
        </h2>
        <p class="text-lg text-gray-600 mb-6">
          The current offer is not just a RoPA register. It is a broader GDPR teamspace built to support related records, follow-up tasks, ownership, and practical privacy operations in one place.
        </p>
        <div class="space-y-4 mb-8">
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <p class="text-gray-700">Supports RoPA and connected register work.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <p class="text-gray-700">Keeps implementation inside tools teams already use.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 bg-[#2b2e83] rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <p class="text-gray-700">Leaves room for future pricing and screenshots without breaking the design.</p>
          </div>
        </div>
        <a href={bookingUrl} class="inline-flex items-center gap-2 px-6 py-3 bg-[#2b2e83] text-white font-semibold rounded-lg hover:bg-[#232465] transition-colors">
          Ask about your setup
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="relative">
        <div class="bg-white rounded-2xl shadow-2xl shadow-[#2b2e83]/10 p-6 border border-gray-100">
          <div class="rounded-xl overflow-hidden">
            <img src="/imgs_callbrad/gdpr1.jpg" alt="GDPR teamspace preview" class="w-full h-auto" />
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-[#ed60ed]/20 rounded-full blur-3xl"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-[#2b2e83]/20 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>

<section class="py-14 lg:py-20 bg-gradient-to-b from-[#2b2e83]/10 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-6">
      Start with the Notion teamspace now
    </h2>
    <p class="text-lg text-gray-600 mb-8">
      Use the existing booking link if you want to discuss which teamspace package fits your team and whether DPO support should sit alongside it.
    </p>
    <a href={bookingUrl} class="inline-flex items-center px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-colors">
      Book an intro call
    </a>
  </div>
</section>
