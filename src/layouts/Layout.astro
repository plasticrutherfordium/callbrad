---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Call Brad - Practical GDPR compliance solutions for startups and growing businesses." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body class="font-roboto text-[#222222] bg-white antialiased">
    
    <!-- Navigation -->
    <nav x-data="{ mobileMenu: false }" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="flex items-center">
            <img src="/imgs_callbrad/CallBradBasic.png" alt="Call Brad" class="h-14 md:h-16 w-auto" />
          </a>
          <div class="hidden md:flex items-center gap-8">
            <a href="/#products" class="text-sm font-medium hover:text-[#2b2e83] transition-colors">Products</a>
            <a href="/myexpertise" class="text-sm font-medium hover:text-[#2b2e83] transition-colors">Expertise</a>
            <a href="/#ropa" class="text-sm font-medium hover:text-[#2b2e83] transition-colors">RoPA System</a>
            <a href="/#training" class="text-sm font-medium hover:text-[#2b2e83] transition-colors">GDPR Training</a>
            <a href="/#dpo" class="text-sm font-medium hover:text-[#2b2e83] transition-colors">DPO Services</a>
            <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="px-4 py-2 bg-[#2b2e83] text-white text-sm font-medium rounded-lg hover:bg-[#232465] transition-colors">Contact</a>
            <a href="/privacy" class="text-sm font-medium text-gray-500 hover:text-[#2b2e83] transition-colors">Privacy</a>
          </div>
          <button @click="mobileMenu = !mobileMenu" class="md:hidden p-2" aria-label="Toggle menu">
            <svg x-show="!mobileMenu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg x-show="mobileMenu" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile Menu -->
      <div x-show="mobileMenu" x-cloak x-transition class="md:hidden bg-white border-t border-gray-100">
        <div class="px-4 py-4 space-y-3">
          <a href="/#products" class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">Products</a>
          <a href="/myexpertise" class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">Expertise</a>
          <a href="/#ropa" class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">RoPA System</a>
          <a href="/#training" class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">Training</a>
          <a href="/#dpo" class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">DPO Services</a>
          <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="block py-2 text-sm font-medium text-[#2b2e83]" @click="mobileMenu = false">Contact</a>
          <a href="/privacy" class="block py-2 text-sm font-medium text-gray-500 hover:text-[#2b2e83]" @click="mobileMenu = false">Privacy</a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#2b2e83] text-white py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-2">
            <a href="/" class="inline-block">
              <img src="/imgs_callbrad/CallBradBasic.png" alt="Call Brad" class="h-14 md:h-16 w-auto" />
            </a>
            <p class="text-white/70 mt-4 max-w-md">
              Practical GDPR compliance solutions for startups and growing businesses. No bloated software. No expensive consultants.
            </p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2 text-white/70">
              <li><a href="/#products" class="hover:text-white transition-colors">Products</a></li>
              <li><a href="/myexpertise" class="hover:text-white transition-colors">Expertise</a></li>
              <li><a href="/#ropa" class="hover:text-white transition-colors">RoPA System</a></li>
              <li><a href="/#training" class="hover:text-white transition-colors">Training</a></li>
              <li><a href="/#dpo" class="hover:text-white transition-colors">DPO Services</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Legal</h4>
            <ul class="space-y-2 text-white/70">
              <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Notice</a></li>
              <li><a href="#" class="hover:text-white transition-colors">Terms of Service</a></li>
            </ul>
          </div>
        </div>
        
        <div class="pt-8 border-t border-white/20 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-white/50 text-sm">
            &copy; 2026 Call Brad. All rights reserved.
          </p>
          <p class="text-white/50 text-sm">
            Company details: Trauko OÜ | Privacy Compliance Services | VAT/Business ID
          </p>
        </div>
      </div>
    </footer>

    <style>
      @import "tailwindcss";
      
      @theme {
        --font-montserrat: "Montserrat", sans-serif;
        --font-roboto: "Roboto", sans-serif;
      }

      [x-cloak] {
        display: none !important;
      }

      html {
        scroll-behavior: smooth;
      }

      .font-montserrat {
        font-family: var(--font-montserrat);
      }

      .font-roboto {
        font-family: var(--font-roboto);
      }
    </style>

    <script>
      document.addEventListener('alpine:init', () => {
        Alpine.data('mobileMenu', () => ({
          mobileMenu: false
        }));
      });
    </script>
  </body>
</html>
