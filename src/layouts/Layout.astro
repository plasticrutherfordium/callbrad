---
import { ClientRouter } from 'astro:transitions';
import { bookingUrl, companyDetails, footerBlurb, footerQuickLinks, navLinks } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Call Brad - Operational GDPR for lean teams." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body class="font-roboto text-[#222222] bg-white antialiased">
    
    <!-- Navigation -->
    <nav x-data="{ mobileMenu: false }" class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="flex items-center">
            <img src="/imgs_callbrad/CallBradBasic.png" alt="Call Brad" class="h-14 md:h-16 w-auto" />
          </a>
          <div class="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium hover:text-[#2b2e83] transition-colors">{link.label}</a>
            ))}
            <a href="/contact" class="px-4 py-2 bg-[#2b2e83] text-white text-sm font-medium rounded-lg hover:bg-[#232465] transition-colors">Contact</a>
          </div>
          <button @click="mobileMenu = !mobileMenu" class="md:hidden p-2" aria-label="Toggle menu">
            <svg x-show="!mobileMenu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg x-show="mobileMenu" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile Menu -->
      <div x-show="mobileMenu" x-cloak x-transition class="md:hidden bg-white border-t border-gray-100">
        <div class="px-4 py-4 space-y-3">
          {navLinks.map((link) => (
            <a href={link.href} class="block py-2 text-sm font-medium hover:text-[#2b2e83]" @click="mobileMenu = false">{link.label}</a>
          ))}
          <a href="/contact" class="block py-2 text-sm font-medium text-[#2b2e83]" @click="mobileMenu = false">Contact</a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#2b2e83] text-white py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-4 gap-8 mb-8">
          <div class="md:col-span-2">
            <a href="/" class="inline-block">
              <img src="/imgs_callbrad/CallBradBasic.png" alt="Call Brad" class="h-14 md:h-16 w-auto" />
            </a>
            <p class="text-white/70 mt-4 max-w-md">
              {footerBlurb}
            </p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2 text-white/70">
              {footerQuickLinks.map((link) => (
                <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Legal</h4>
            <ul class="space-y-2 text-white/70">
              <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Notice</a></li>
            </ul>
          </div>
        </div>
        
        <div class="pt-8 border-t border-white/20 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-white/50 text-sm">
            &copy; 2026 Call Brad. All rights reserved.
          </p>
          <p class="text-white/50 text-sm">
            Company details: {companyDetails}
          </p>
        </div>
      </div>
    </footer>

    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>

    <script>
      document.addEventListener('alpine:init', () => {
        Alpine.data('mobileMenu', () => ({
          mobileMenu: false
        }));
      });
    </script>
  </body>
</html>
